#!/usr/bin/env bash
# Bootstrap editor configs: LazyVim plugins + Doom Emacs.
set -euo pipefail

for p in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
  [ -x "$p" ] && eval "$("$p" shellenv)" && break
done

# --- Neovim / LazyVim -------------------------------------------------------
if command -v nvim >/dev/null 2>&1; then
  echo "==> Syncing LazyVim plugins (headless)"
  nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
fi

# --- Doom Emacs -------------------------------------------------------------
# The framework itself is cloned to ~/.config/emacs by .chezmoiexternal.toml;
# our config lives in ~/.config/doom. `doom sync` reconciles the two.
DOOM_BIN="$HOME/.config/emacs/bin/doom"
if [ -x "$DOOM_BIN" ] && command -v emacs >/dev/null 2>&1; then
  echo "==> doom sync"
  # `doom sync` builds packages + profile from ~/.config/doom on a fresh clone
  # too — no `doom install` needed. (doom install is an interactive wizard whose
  # flags drift between versions; --no-fonts was removed in Doom 2.2.)
  "$DOOM_BIN" sync || true
fi
# --- tmux plugins (tpm cloned via .chezmoiexternal.toml) --------------------
if [ -x "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]; then
  echo "==> Installing tmux plugins"
  "$HOME/.tmux/plugins/tpm/bin/install_plugins" || true
fi

# --- git-lfs global filters (global hooks suggest LFS for large files) ------
if command -v git-lfs >/dev/null 2>&1; then
  git lfs install --skip-repo >/dev/null 2>&1 || true
fi
echo "==> editors done"

# --- change detection: re-run (hence `doom sync`) on any Doom config edit ----
# Embeds a hash of each ~/.config/doom file, so enabling a module or adding a
# package re-triggers this script and `doom sync` installs it — no manual sync,
# no void-function from an unsynced package. Mirrors packages.yaml's wiring.
{{ range (glob (joinPath .chezmoi.sourceDir "dot_config" "doom" "*")) -}}
# {{ base . }} {{ include (printf "dot_config/doom/%s" (base .)) | sha256sum }}
{{ end -}}
