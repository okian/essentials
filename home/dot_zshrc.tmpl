{{- $brew := "/home/linuxbrew/.linuxbrew" -}}
{{- if .isMac -}}{{- if eq .chezmoi.arch "arm64" -}}{{- $brew = "/opt/homebrew" -}}{{- else -}}{{- $brew = "/usr/local" -}}{{- end -}}{{- end -}}
# .zshrc — fallback shell (default is nushell). Managed by chezmoi.

# Homebrew
[ -x "{{ $brew }}/bin/brew" ] && eval "$({{ $brew }}/bin/brew shellenv)"

# PATH
export PATH="$HOME/.swiftly/bin:$HOME/.cargo/bin:$HOME/go/bin:$HOME/.local/bin:$HOME/bins:$PATH"
# Neovim is THE editor everywhere.
export EDITOR=nvim VISUAL=nvim GIT_EDITOR=nvim KUBE_EDITOR=nvim
# Pretty man pages via bat.
if command -v bat >/dev/null; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  export MANROFFOPT=-c
fi

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS INC_APPEND_HISTORY

# Completions + vi mode
autoload -Uz compinit && compinit
bindkey -v
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# fzf: drive with fd; bat/eza previews on Ctrl-T (files) and Alt-C (dirs).
if command -v fd >/dev/null; then
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
  # Catppuccin Mocha palette — matches WezTerm/tmux/Neovim.
  export FZF_DEFAULT_OPTS='--height 45% --layout reverse --border --info inline --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8'
  export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers {} 2>/dev/null || eza --tree --color=always {}'"
  export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --color=always {}'"
fi

# Fuzzy-find a file and open it in $EDITOR.
ff() { local f; f=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --color=always --style=numbers {} 2>/dev/null'); [ -n "$f" ] && ${EDITOR:-nvim} "$f"; }
# Fuzzy-find a directory and cd into it.
fcd() { local d; d=$(fd --type d --hidden --follow --exclude .git | fzf --preview 'eza --tree --level=2 --color=always {}'); [ -n "$d" ] && cd "$d"; }
# `y` opens yazi and cd's to wherever you quit it (`command cat` dodges the bat
# alias; preserves yazi/cd exit status and always removes the temp file).
y() {
  local tmp cwd status
  tmp="$(mktemp -t yazi-cwd.XXXXXX)" || return
  yazi "$@" --cwd-file="$tmp"
  status=$?
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    cd -- "$cwd" || status=$?
  fi
  rm -f -- "$tmp"
  return "$status"
}

# Aliases
alias ll='eza -la --icons --group-directories-first 2>/dev/null || ls -la'
alias lt='eza --tree --level=2 --icons'
alias g='git' lg='lazygit' v='nvim' vim='nvim' cat='bat'
alias top='btop'
alias nu='nu'   # drop into nushell anytime
# Container muscle-memory: docker -> podman
alias docker='podman' docker-compose='podman-compose' dc='podman-compose'

# Integrations
command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide   >/dev/null && eval "$(zoxide init zsh)"
command -v direnv   >/dev/null && eval "$(direnv hook zsh)"
command -v atuin    >/dev/null && eval "$(atuin init zsh)"
command -v carapace >/dev/null && { export CARAPACE_BRIDGES='zsh,fish,bash'; source <(carapace _carapace zsh); }
[ -f "$(brew --prefix 2>/dev/null)/opt/fzf/shell/key-bindings.zsh" ] && \
  source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
[ -f "$(brew --prefix 2>/dev/null)/opt/fzf/shell/completion.zsh" ] && \
  source "$(brew --prefix)/opt/fzf/shell/completion.zsh"

# zsh-autosuggestions + fast-syntax-highlighting (load highlighting LAST)
_brew_prefix="$(brew --prefix 2>/dev/null)"
[ -f "$_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && \
  source "$_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
[ -f "$_brew_prefix/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ] && \
  source "$_brew_prefix/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
unset _brew_prefix

# Random usage tip on interactive startup (opt out: export ESSENTIALS_NO_TIPS=1).
if [[ -o interactive && -z "${ESSENTIALS_NO_TIPS:-}" && -r ~/.config/essentials/tips.txt ]]; then
  _tip=$(grep -vE '^[[:space:]]*(#|$)' ~/.config/essentials/tips.txt | sort -R | head -1)
  [ -n "$_tip" ] && print -P "%B%F{yellow}💡 tip%f%b ${_tip} %F{8}— cheatsheet: ~/.config/essentials/cheatsheet.md%f"
  unset _tip
fi
# Quick doc helpers in the fallback shell, mirroring nushell's `essentials`.
tips()       { grep -vE '^[[:space:]]*(#|$)' ~/.config/essentials/tips.txt; }
cheatsheet() { bat --style=plain --paging=always -l md ~/.config/essentials/cheatsheet.md 2>/dev/null || cat ~/.config/essentials/cheatsheet.md; }
