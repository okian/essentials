#!/usr/bin/env bash
# Regenerate per-entity git identity includes from ~/repos on every apply.
# The logic lives in ~/bins/git-identities-sync so provisioning and
# `essentials git-identity sync` share one implementation. Quiet unless
# something changes; never hard-fails (provisioning must not break on it).
set -euo pipefail

sync="{{ .chezmoi.homeDir }}/bins/git-identities-sync"
if [ -x "$sync" ]; then
  "$sync" --quiet || echo "⚠ git-identities-sync failed; continuing"
fi
