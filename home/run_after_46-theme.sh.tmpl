#!/usr/bin/env bash
# Generate the active-theme artifacts (palette.json, active-theme.sh, tmux +
# starship copies) for the current theme — or the built-in default on a fresh
# machine — so every tool has them on first launch. Runs on every apply (cheap,
# idempotent), which also re-asserts the theme after chezmoi rewrites the
# managed configs it derives from. Logic lives in dots' themes.nu.
set -euo pipefail

nu_bin="$(command -v nu || true)"
themes="$HOME/.config/dots/themes.nu"
if [ -n "$nu_bin" ] && [ -f "$themes" ]; then
  "$nu_bin" --no-config-file --commands "source $themes; _theme_apply (_theme_current)" || true
fi
