#!/usr/bin/env bash
# Install Homebrew (both OSes) + all packages from packages.yaml.
# This script embeds the package list, so editing packages.yaml changes the
# rendered content and chezmoi re-runs it automatically.
set -euo pipefail

SUDO=""
if [ "$(id -u)" -ne 0 ]; then SUDO="sudo"; fi

# --- Homebrew ---------------------------------------------------------------
if ! command -v brew >/dev/null 2>&1; then
  echo "==> Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Make brew available in this shell (paths differ by OS/arch).
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

{{ if .isMac -}}
# One-time migration: drop the old emacs-app cask (precompiled, no HarfBuzz /
# native-comp) so emacs-plus@30 can own the `emacs` symlink without a clash.
if brew list --cask emacs-app >/dev/null 2>&1; then
  echo "==> removing emacs-app cask (superseded by emacs-plus@30)"
  brew uninstall --cask emacs-app || true
fi

# A homebrew-core `emacs` formula owns the same bins (emacs/emacsclient/etags…)
# and blocks emacs-plus@30 from linking during the bundle. Unlink it first.
if brew list --formula emacs >/dev/null 2>&1; then
  echo "==> unlinking core emacs formula (conflicts with emacs-plus@30)"
  brew unlink emacs || true
fi

# Tap + trust third-party taps *before* the bundle. Recent Homebrew refuses to
# load a formula from an untrusted tap; `brew trust` whitelists it. Both are
# best-effort: older Homebrew has no `trust` subcommand and requires no trust.
{{ range .packages.brew_taps -}}
brew tap {{ . }} >/dev/null 2>&1 || true
brew trust {{ . }} </dev/null >/dev/null 2>&1 || true
{{ end -}}
{{ end -}}

echo "==> brew bundle"
# HOMEBREW_NO_AUTO_UPDATE: don't let brew rebase its own repos mid-bundle
# (noisy, and slow); `dots update` refreshes Homebrew separately.
HOMEBREW_NO_AUTO_UPDATE=1 brew bundle --file=/dev/stdin <<'BREWFILE'
{{ range .packages.brew_formulae -}}
brew "{{ . }}"
{{ end -}}
{{ if .isMac -}}
{{ range .packages.mac_brew_formulae -}}
brew "{{ . }}"
{{ end -}}
{{ range .packages.brew_casks -}}
cask "{{ . }}"
{{ end -}}
{{ end -}}
BREWFILE

{{ if .isMac -}}
# emacs-plus installs Emacs.app under the Cellar; link it where Spotlight,
# Finder, and `open -a Emacs` look (~/Applications is user-writable, no sudo).
if brew list --formula emacs-plus@30 >/dev/null 2>&1; then
  # Ensure emacs-plus owns the CLI symlinks even if a core `emacs` formula built
  # them first (its link step can fail mid-bundle, leaving emacs-plus unlinked).
  brew unlink emacs >/dev/null 2>&1 || true
  brew link --overwrite emacs-plus@30 >/dev/null 2>&1 || true
  emacs_app="$(brew --prefix)/opt/emacs-plus@30/Emacs.app"
  if [ -d "$emacs_app" ]; then
    mkdir -p "$HOME/Applications"
    ln -sfn "$emacs_app" "$HOME/Applications/Emacs.app"
    echo "==> linked Emacs.app -> $emacs_app"
  fi
fi
{{ end -}}

{{ if .isLinux -}}
# --- Linux GUI extras (best effort; only meaningful on a desktop) -----------
if command -v apt-get >/dev/null 2>&1; then
  export DEBIAN_FRONTEND=noninteractive
  $SUDO apt-get install -y {{ range .packages.linux_apt }}{{ . }} {{ end }}|| true
fi
if command -v flatpak >/dev/null 2>&1; then
  {{ range .packages.linux_flatpak -}}
  flatpak install -y --noninteractive flathub {{ . }} || true
  {{ end -}}
fi
{{ end -}}

# --- Nerd Fonts (both OSes; direct from nerd-fonts releases) ----------------
# JetBrainsMono for the terminal/editor; Symbols-only for Doom Emacs / nerd-icons
# (doom doctor wants the "Symbols Nerd Font Mono" family). Direct unzip rather
# than a brew cask: casks "adopt" pre-existing font files and abort on checksum
# mismatch; `cp -f` just overwrites.
{{ if .isMac -}}
fontdir="$HOME/Library/Fonts"
{{ else -}}
fontdir="$HOME/.local/share/fonts"
{{ end -}}
mkdir -p "$fontdir"

# install_nerd_font <release-zip> <glob-that-proves-it-is-already-installed>
install_nerd_font() {
  local zip="$1" probe="$2" tmpd
  if compgen -G "$fontdir/$probe" >/dev/null; then return; fi
  echo "==> Installing Nerd Font: $zip"
  tmpd="$(mktemp -d)"
  if curl -fsSL -o "$tmpd/f.zip" \
      "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/$zip"; then
    mkdir -p "$tmpd/x"
    unzip -oq "$tmpd/f.zip" -d "$tmpd/x"
    cp -f "$tmpd/x"/*.ttf "$fontdir"/ 2>/dev/null || true
    cp -f "$tmpd/x"/*.otf "$fontdir"/ 2>/dev/null || true
  fi
  rm -rf "$tmpd"
}

install_nerd_font "JetBrainsMono.zip"        "JetBrainsMono*NerdFont*"
install_nerd_font "NerdFontsSymbolsOnly.zip" "SymbolsNerdFont*"
{{ if .isLinux -}}
if command -v fc-cache >/dev/null 2>&1; then
  fc-cache -f "$fontdir" >/dev/null 2>&1 || true
fi
{{ end -}}
echo "==> packages done"
