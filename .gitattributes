# Font binaries via Git LFS — versions large blobs cleanly and keeps them under
# the pre-commit large-file guard (the staged blob is a small LFS pointer).
# LUTs (.cube/.3dl) and DCTLs (.dctl) are plain text and are NOT tracked here.
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
*.ttc filter=lfs diff=lfs merge=lfs -text
*.TTF filter=lfs diff=lfs merge=lfs -text
*.OTF filter=lfs diff=lfs merge=lfs -text
*.TTC filter=lfs diff=lfs merge=lfs -text
